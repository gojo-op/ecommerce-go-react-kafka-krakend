{
  "version": 3,
  "name": "fullstack-demo-krakend",
  "port": 8080,
  "endpoints": [
    { "endpoint": "/api/v1/auth/register", "method": "POST", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/register" } ] },
    { "endpoint": "/api/v1/auth/login", "method": "POST", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/login" } ] },
    { "endpoint": "/api/v1/auth/refresh", "method": "POST", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/refresh" } ] },
    { "endpoint": "/api/v1/auth/logout", "method": "POST", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/logout" } ] },
    { "endpoint": "/api/v1/auth/profile", "method": "GET",  "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/profile" } ] },
