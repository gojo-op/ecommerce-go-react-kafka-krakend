    { "endpoint": "/api/v1/products", "method": "GET", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://product-service:8082"], "url_pattern": "/api/v1/products" } ] },
    { "endpoint": "/api/v1/products", "method": "POST", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://product-service:8082"], "url_pattern": "/api/v1/products" } ] },
    { "endpoint": "/api/v1/products/{id}", "method": "GET", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://product-service:8082"], "url_pattern": "/api/v1/products/{id}" } ] },
    { "endpoint": "/api/v1/products/sku/{sku}", "method": "GET", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://product-service:8082"], "url_pattern": "/api/v1/products/sku/{sku}" } ] },
    { "endpoint": "/api/v1/products/{id}", "method": "PUT", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://product-service:8082"], "url_pattern": "/api/v1/products/{id}" } ] },
    { "endpoint": "/api/v1/products/{id}", "method": "DELETE", "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://product-service:8082"], "url_pattern": "/api/v1/products/{id}" } ] },
