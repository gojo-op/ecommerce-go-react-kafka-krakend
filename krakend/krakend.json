    { "endpoint": "/api/v1/auth/change-password", "method": "POST",  "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/change-password" } ] },
    { "endpoint": "/api/v1/auth/users/{user_id}/roles", "method": "POST",  "output_encoding": "json", "extra_config": { "github_com/devopsfaith/krakend/proxy": { "preserve_query": true } }, "backend": [ { "host": ["http://auth-service:8081"], "url_pattern": "/api/v1/auth/users/{user_id}/roles" } ] },
